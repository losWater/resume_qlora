# 虚拟环境（绝不提交，几个 GB）
.venv/

# 密钥 / 配置
.env

# Python 缓存
__pycache__/
*.py[cod]
*.egg-info/

# 基座模型（体积大，用 download_model.py 重新下载）
models/
checkpoints/
*.gguf

# 训练 checkpoint（体积大，可重新训练；保留最终 adapter 以便直接加载）
outputs/**/checkpoint-*/

# 训练监控本地缓存
swanlog/
wandb/

# 注：合成简历数据 data/*.jsonl 与最终 LoRA adapter 已纳入版本库

# 仅本地保留, 不入库：个人读代码 / 理解项目的指引
代码阅读指引.md

# 系统
.DS_Store
Thumbs.db
